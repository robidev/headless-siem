[Unit]
Description=Headless SIEM - Sigma Rule Engine
Documentation=https://github.com/your-org/headless-siem
After=network.target headless-siem-pipes.service headless-siem-normalized.service
Requires=headless-siem-pipes.service
Wants=headless-siem-normalized.service

[Service]
Type=simple
User=user
Environment=HEADLESS_SIEM_ROOT=/home/user/projects/headless-siem
WorkingDirectory=/home/user/projects/headless-siem
ExecStart=/home/user/projects/headless-siem/src/ruled/target/release/ruled \
  --rules /home/user/projects/headless-siem/config/rules \
  --output /home/user/projects/headless-siem/data/alerts
StandardInput=file:/run/headless-siem/normalized-out.pipe
StandardOutput=file:/run/headless-siem/ruled-out.pipe
StandardError=journal
Restart=on-failure
RestartSec=5

# Security hardening
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=yes
ReadWritePaths=/home/user/projects/headless-siem/data/alerts /run/headless-siem
ReadOnlyPaths=/home/user/projects/headless-siem/config

[Install]
WantedBy=multi-user.target
