#!/usr/bin/env bash
# redeploy-binary — build and install ONE binary from the current repo
# checkout, and stamp it in /etc/headless-siem/.deployed-revisions.
#
# This is the targeted-hotfix path: re-running the full production
# `config/systemd/install.sh` (which rewrites config, restarts every
# service, etc.) is overkill for "one crate got a one-line fix and needs
# to go live." Use that installer instead for anything touching config/
# systemd units, or a first-time install.
#
# USAGE:
#   sudo scripts/redeploy-binary <normalized|indexd|ruled|correlated|siemctl> [--restart]
#
# Without --restart: builds, installs, stamps the revision, and prints a
# reminder if the target is a long-running service (`install`'s atomic
# unlink+rename means an already-running process keeps its old inode
# open — the new binary is on disk but NOT live until the service is
# restarted). siemctl has no running process, so this never applies to it.
#
# With --restart: also runs `systemctl restart` on the matching unit.
# Deliberately opt-in, not the default — restarting a live pipeline
# component is exactly what caused the pipe-EOF/syslogd-crash incidents
# documented in llm-based-soc's archived plan issues #46/#47, so this script
# won't do it silently.

set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
REV_FILE=/etc/headless-siem/.deployed-revisions

usage() {
    echo "Usage: sudo scripts/redeploy-binary <normalized|indexd|ruled|correlated|siemctl> [--restart]" >&2
    exit 1
}

[[ $# -ge 1 ]] || usage
CRATE="$1"
shift || true
DO_RESTART=0
if [[ "${1:-}" == "--restart" ]]; then
    DO_RESTART=1
    shift || true
fi

case "$CRATE" in
    normalized|indexd|ruled|correlated) DEST_NAME="headless-siem-${CRATE}"; UNIT="headless-siem-${CRATE}.service" ;;
    siemctl) DEST_NAME="siemctl"; UNIT="" ;;
    *) echo "ERROR: unknown crate '$CRATE'"; usage ;;
esac

if [[ $EUID -ne 0 ]]; then
    echo "ERROR: this must be run as root (sudo) — it installs to /usr/local/bin and writes $REV_FILE."
    exit 1
fi

echo "=== Building $CRATE (release) ==="
# cargo lives under ~/.cargo/bin, which sudo's secure_path strips (same
# gotcha as `claude` itself) — invoke it by full path rather than relying
# on PATH surviving sudo -u.
BUILD_USER="${SUDO_USER:-$(id -un)}"
CARGO_BIN="$(sudo -u "$BUILD_USER" bash -lc 'command -v cargo' 2>/dev/null || true)"
[[ -n "$CARGO_BIN" ]] || { echo "ERROR: couldn't resolve cargo for user $BUILD_USER (checked via login shell PATH)"; exit 1; }
sudo -u "$BUILD_USER" bash -c "cd '$PROJECT_ROOT' && '$CARGO_BIN' build --release -p '$CRATE'"

BIN_PATH="$PROJECT_ROOT/target/release/$CRATE"
[[ -x "$BIN_PATH" ]] || { echo "ERROR: build did not produce $BIN_PATH"; exit 1; }

echo "=== Installing to /usr/local/bin/$DEST_NAME ==="
install -m 755 "$BIN_PATH" "/usr/local/bin/$DEST_NAME"

echo "=== Recording deployed revision ==="
mkdir -p /etc/headless-siem
GIT_HEAD="$(git -C "$PROJECT_ROOT" rev-parse HEAD)"
DEPLOY_TS="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
if [[ -f "$REV_FILE" ]]; then
    grep -v "^${CRATE}=" "$REV_FILE" > "${REV_FILE}.tmp" || true
    mv "${REV_FILE}.tmp" "$REV_FILE"
fi
echo "${CRATE}=${GIT_HEAD} ${DEPLOY_TS}" >> "$REV_FILE"
sort -o "$REV_FILE" "$REV_FILE"
echo "  Stamped ${CRATE}=${GIT_HEAD:0:8} at ${DEPLOY_TS}"

if [[ -n "$UNIT" ]]; then
    if [[ "$DO_RESTART" -eq 1 ]]; then
        echo "=== Restarting $UNIT ==="
        systemctl restart "$UNIT"
        sleep 1
        systemctl is-active --quiet "$UNIT" && echo "  $UNIT: active" || echo "  WARNING: $UNIT not active after restart"
    else
        echo "NOTE: $UNIT is still running the OLD binary until it's restarted."
        echo "      systemctl restart $UNIT   # when ready"
    fi
fi

echo "=== Done ==="
