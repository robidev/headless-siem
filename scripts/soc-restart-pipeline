#!/usr/bin/env bash
# soc-restart-pipeline — the single wrapper the analyst role calls to
# recover a down local logging-pipeline component. Deliberately takes NO
# arguments: this is invoked from a cron role that processes
# attacker-controlled log/alert content, so nothing about what it does
# can be influenced by that content — it always does exactly the same
# fixed check, against a fixed list of unit names, nothing else.
#
# Checks these 5 units in order and restarts only the ones that are not
# already active (never touches a healthy unit — restarting a *working*
# service is what caused the pipe-EOF and syslogd-crash incidents this
# script exists to catch, see implementation-plan.md issues #46/#47):
#   headless-siem-normalized
#   headless-siem-indexd
#   headless-siem-ruled
#   headless-siem-correlated
#   headless-siem-alert-watch
#
# USAGE:
#   soc-restart-pipeline
#
# Prints one line per unit ("already active" / "was down, restarted,
# now active" / "was down, restarted, STILL NOT ACTIVE") and a final
# summary line. Exit 0 if every unit is active by the end (whether it
# needed restarting or not), exit 1 if any unit is still not active
# after a restart attempt — the analyst uses this exit code to decide
# ticket severity and whether to escalate.

set -uo pipefail

UNITS=(
    headless-siem-normalized
    headless-siem-indexd
    headless-siem-ruled
    headless-siem-correlated
    headless-siem-alert-watch
)

# Rate-limit (runner-and-permissions.md §11.2(1)): a prompt-injected
# analyst could be steered to trigger restarts repeatedly, and a restart
# is exactly what caused the syslogd-crash/pipe-EOF incidents (#46/#47).
# So: refuse to restart again within COOLDOWN of a prior restart, and
# fire a deterministic soc-notify on every actual restart / rate-limit —
# deterministic here means it can't be suppressed by whatever got the
# analyst to call this in the first place.
COOLDOWN=$((10 * 60))
STATE_DIR=/var/lib/soc/restart-state
STATE_FILE="$STATE_DIR/last-restart.epoch"
# [SOC-ROOT-PATH] decisions.md 5.1b — cross-repo path to the notifier.
SOC_NOTIFY=/home/user/projects/llm-based-soc/scripts/soc-notify

notify() {  # <priority> <message>
    [ -x "$SOC_NOTIFY" ] || return 0
    sudo -u soc-infra "$SOC_NOTIFY" "$1" "$2" >/dev/null 2>&1 || true
}

# --- pass 1: which units are down (checking is always safe) ---
down=()
for unit in "${UNITS[@]}"; do
    if systemctl is-active --quiet "$unit"; then
        echo "$unit: already active"
    else
        echo "$unit: not active"
        down+=("$unit")
    fi
done

if [ "${#down[@]}" -eq 0 ]; then
    echo "summary: all units were already active, nothing restarted"
    exit 0
fi

# --- rate-limit gate: down units, but did we just restart? ---
now="$(date -u +%s)"
last=0
if [ -r "$STATE_FILE" ]; then
    read -r last < "$STATE_FILE" 2>/dev/null || last=0
    case "$last" in ''|*[!0-9]*) last=0 ;; esac   # only a clean epoch counts
fi
if [ "$last" -gt 0 ] && [ "$((now - last))" -lt "$COOLDOWN" ]; then
    echo "summary: ${#down[@]} unit(s) down but a restart was attempted $((now - last))s ago (< ${COOLDOWN}s) — RATE-LIMITED, not restarting"
    notify high "soc-restart-pipeline RATE-LIMITED: ${down[*]} still down $((now - last))s after a prior restart — possible restart loop / injection; human check needed"
    exit 1
fi

# --- restart pass ---
mkdir -p "$STATE_DIR" 2>/dev/null || true
printf '%s\n' "$now" > "$STATE_FILE" 2>/dev/null || true
overall_ok=0
for unit in "${down[@]}"; do
    echo "$unit: restarting"
    systemctl restart "$unit" 2>&1 || true
    sleep 2
    if systemctl is-active --quiet "$unit"; then
        echo "$unit: restarted, now active"
    else
        echo "$unit: restarted, STILL NOT ACTIVE"
        overall_ok=1
    fi
done

if [ "$overall_ok" -eq 0 ]; then
    echo "summary: one or more units were down, all now active after restart"
    notify high "soc-restart-pipeline restarted (now healthy): ${down[*]}"
else
    echo "summary: one or more units are still not active after a restart attempt"
    notify high "soc-restart-pipeline restart FAILED, still down: ${down[*]} — human intervention needed"
fi

exit "$overall_ok"
